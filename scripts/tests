#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Build if needed
go build -o "$PROJECT_DIR/dist/fzfg" "$PROJECT_DIR/cmd/fzfg/"

# Use local binary and config
fzfg="$PROJECT_DIR/dist/fzfg"
export FZFG_CONF="$PROJECT_DIR/configs/fzfg.yaml"

printf '\e[34mTesting missing keys with error messages\e[0m\n'

printf '\e[90m$ $fzfg -c missing_command -o missing_options\e[0m\n'
$fzfg -c missing_command -o missing_options

printf '\e[90m$ $fzfg -c missing_command\e[0m\n'
$fzfg -c missing_command

printf '\e[90m$ $fzfg -o missing_options\e[0m\n'
$fzfg -o missing_options

printf '\e[90m$ $fzfg -p missing_profile\e[0m\n'
$fzfg -p missing_profile

# ----------------------------------------------------------------------------

printf '\e[34mTesting missing keys without error messages\e[0m\n'

printf '\e[90m$ $fzfg -q -c missing_command -o missing_options\e[0m\n'
$fzfg -q -c missing_command -o missing_options

printf '\e[90m$ $fzfg -q -c missing_command\e[0m\n'
$fzfg -q -c missing_command

printf '\e[90m$ $fzfg -q -o missing_options\e[0m\n'
$fzfg -q -o missing_options

printf '\e[90m$ $fzfg -q -p missing_profile\e[0m\n'
$fzfg -q -p missing_profile

# ----------------------------------------------------------------------------

printf '\e[34mTesting invalid configuration with error messages\e[0m\n'

printf '\e[90m$ $fzfg -c invalid_command -o invalid_options\e[0m\n'
$fzfg -c invalid_command -o invalid_options

printf '\e[90m$ $fzfg -c invalid_command\e[0m\n'
$fzfg -c invalid_command

printf '\e[90m$ $fzfg -o invalid_options\e[0m\n'
$fzfg -o invalid_options

printf '\e[90m$ $fzfg -p invalid_profile\e[0m\n'
$fzfg -p invalid_profile

# ----------------------------------------------------------------------------

printf '\e[34mTesting invalid configuration without error messages\e[0m\n'

printf '\e[90m$ $fzfg -q -c invalid_command -o invalid_options\e[0m\n'
$fzfg -q -c invalid_command -o invalid_options

printf '\e[90m$ $fzfg -q -c invalid_command\e[0m\n'
$fzfg -q -c invalid_command

printf '\e[90m$ $fzfg -q -o invalid_options\e[0m\n'
$fzfg -q -o invalid_options

printf '\e[90m$ $fzfg -q -p invalid_profile\e[0m\n'
$fzfg -q -p invalid_profile

# ----------------------------------------------------------------------------

printf '\e[34mTesting existing keys with raw format\e[0m\n'

printf '\e[90m$ $fzfg -r -c fd_files -o preview\e[0m\n'
$fzfg -r -c fd_files -o preview

printf '\e[90m$ $fzfg -r -c fd_files\e[0m\n'
$fzfg -r -c fd_files

printf '\e[90m$ $fzfg -r -o preview\e[0m\n'
$fzfg -r -o preview

printf '\e[90m$ $fzfg -r -p view_files\e[0m\n'
$fzfg -r -p view_files

# ----------------------------------------------------------------------------

printf '\e[34mTesting existing keys without raw format\e[0m\n'

printf '\e[90m$ $fzfg -c fd_files -o preview\e[0m\n'
$fzfg -c fd_files -o preview

printf '\e[90m$ $fzfg -c fd_files\e[0m\n'
$fzfg -c fd_files

printf '\e[90m$ $fzfg -o preview\e[0m\n'
$fzfg -o preview

printf '\e[90m$ $fzfg -p view_files\e[0m\n'
$fzfg -p view_files
